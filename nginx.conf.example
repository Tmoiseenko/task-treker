# Настройка для HTTP (без SSL)
# Используйте этот блок для начальной настройки
server {
    listen 80;
    listen [::]:80;
    server_name your-domain.com www.your-domain.com;
    
    # Корневая директория (public папка Laravel)
    root /var/www/project-management/public;
    index index.php index.html;
    
    # Безопасность
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    
    # Кодировка
    charset utf-8;
    
    # Основная локация
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    
    # Обработка PHP файлов
    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        
        # Таймауты для длительных операций
        fastcgi_read_timeout 300;
        fastcgi_send_timeout 300;
    }
    
    # Отключить логирование для статических файлов
    location = /favicon.ico { 
        access_log off; 
        log_not_found off; 
    }
    
    location = /robots.txt  { 
        access_log off; 
        log_not_found off; 
    }
    
    # Запретить доступ к скрытым файлам
    location ~ /\.(?!well-known).* {
        deny all;
    }
    
    # Запретить доступ к конфигурационным файлам
    location ~ /\.(env|git|gitignore|gitattributes) {
        deny all;
    }
    
    # Обработка ошибок
    error_page 404 /index.php;
    
    # Логи
    access_log /var/log/nginx/project-management-access.log;
    error_log /var/log/nginx/project-management-error.log;
    
    # Максимальный размер загружаемых файлов
    client_max_body_size 100M;
}

# Инструкции по установке:
# 1. Замените your-domain.com на ваш домен
# 2. Скопируйте файл: sudo cp nginx.conf.example /etc/nginx/sites-available/project-management
# 3. Создайте символическую ссылку: sudo ln -s /etc/nginx/sites-available/project-management /etc/nginx/sites-enabled/
# 4. Проверьте конфигурацию: sudo nginx -t
# 5. Перезагрузите Nginx: sudo systemctl reload nginx
# 6. Для SSL используйте Let's Encrypt: sudo certbot --nginx -d your-domain.com -d www.your-domain.com
